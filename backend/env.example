# Konnaxion backend environment template
# Copy this file to backend/.env for local non-Docker development.
# Do NOT commit real secrets.

# Read .env file in local/dev
DJANGO_READ_DOT_ENV_FILE=true
DJANGO_READ_ENV_FILE=true

# Local development settings
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-in-local-dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (example: Neon)
# Replace with a real connection string in your local .env only.
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_NEON_HOST/YOUR_DB?sslmode=require&channel_binding=require

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
USE_DOCKER=no

# Search backend
SEARCH_BACKEND=postgres

# Optional module settings
# EKOH_MIN_MULTIPLIER=0.20
# EKOH_MAX_MULTIPLIER=1.50
# KC_VIDEO_PROVIDER=livekit
# OFFLINE_PACKAGE_CRON=0 3 * * SUN

# Optional analytics settings
# REPORTS_DB_URL=
# PROMETHEUS_BASE_URL=http://localhost:9090
# EXPORT_MAX_ROWS=100000

# Optional streaming / integration settings
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
