  "topics": [
    {
      "key": "ai_classroom_policy",
      "title": "[DEMO] Should schools allow supervised AI tutoring tools?",
      "description": "The community is debating whether AI tutors should be allowed under teacher oversight, district procurement, audit logs, and clear student-use rules.",
      "status": "open",
      "category": "education",
      "start_date": "2026-05-01",
      "end_date": "2026-07-05"
    },
    {
      "key": "ai_assessment_integrity",
      "title": "[DEMO] How should schools protect assessment integrity in the AI era?",
      "description": "Teachers, students, and parents are weighing disclosure rules, oral defenses, in-class assessment, process logs, and restorative responses to misuse.",
      "status": "open",
      "category": "education",
      "start_date": "2026-05-01",
      "end_date": "2026-07-05"
    },
    {
      "key": "student_data_privacy",
      "title": "[DEMO] What privacy rules should govern student data used by AI tools?",
      "description": "The board must decide what data can be processed, where it can be stored, how long it can be retained, and whether vendors may train models on student work.",
      "status": "open",
      "category": "digital_safety",
      "start_date": "2026-05-01",
      "end_date": "2026-07-05"
    },
    {
      "key": "teacher_workload_training",
      "title": "[DEMO] How should teachers be supported before AI tools enter classrooms?",
      "description": "The discussion focuses on training time, classroom templates, technical support, workload protection, and teacher autonomy.",
      "status": "open",
      "category": "education",
      "start_date": "2026-05-01",
      "end_date": "2026-07-05"
    },
    {
      "key": "equity_access_funding",
      "title": "[DEMO] How can schools avoid widening inequality through AI adoption?",
      "description": "Participants are considering device access, language support, disability accommodations, free district-provided tools, and targeted support for underserved students.",
      "status": "open",
      "category": "equity",
      "start_date": "2026-05-01",
      "end_date": "2026-07-05"
    },
    {
      "key": "ai_literacy_curriculum",
      "title": "[DEMO] Should AI literacy become part of the core curriculum?",
      "description": "The district is considering a required AI literacy strand covering prompting, verification, bias, privacy, authorship, and responsible use.",
      "status": "open",
      "category": "digital_safety",
      "start_date": "2026-05-01",
      "end_date": "2026-07-05"
    }
  ],
