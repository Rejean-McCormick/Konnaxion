  "arguments": [
    {
      "key": "lina_access",
      "topic": "ai_classroom_policy",
      "actor": "lina",
      "side": "pro",
      "content": "AI tutors could help students who need extra explanations outside classroom hours, especially before exams or when homework instructions are unclear."
    },
    {
      "key": "teacher_integrity",
      "topic": "ai_classroom_policy",
      "actor": "marc_teacher",
      "side": "neutral",
      "content": "The policy must separate learning support from uncredited assignment completion, otherwise teachers will not know what students actually understand."
    },
    {
      "key": "parent_equity",
      "topic": "ai_classroom_policy",
      "actor": "fatima_parent",
      "side": "con",
      "content": "If access depends on paid tools, the policy may increase inequality between students whose families can afford subscriptions and those who cannot."
    },
    {
      "key": "admin_safeguards",
      "topic": "ai_classroom_policy",
      "actor": "elise_admin",
      "side": "pro",
      "content": "A district-provided tool with logs, privacy review, teacher oversight, and opt-out options is safer than informal unsupervised use."
    },
    {
      "key": "privacy_caution",
      "topic": "ai_classroom_policy",
      "actor": "noor_privacy",
      "side": "neutral",
      "content": "Approval should be conditional on a data-protection impact assessment and a clear rule that student data is not used to train vendor models."
    },
    {
      "key": "teacher_process_evidence",
      "topic": "ai_assessment_integrity",
      "actor": "marc_teacher",
      "side": "pro",
      "content": "Major assignments should require process evidence, such as outlines, drafts, notes, reflections, or short oral checks."
    },
    {
      "key": "student_clear_rules",
      "topic": "ai_assessment_integrity",
      "actor": "lina",
      "side": "pro",
      "content": "Students need clear examples of allowed help, forbidden substitution, and how to cite AI assistance without being punished for honest disclosure."
    },
    {
      "key": "parent_trust_grades",
      "topic": "ai_assessment_integrity",
      "actor": "fatima_parent",
      "side": "pro",
      "content": "Families need to trust that grades still reflect learning, not just the ability to operate a chatbot."
    },
    {
      "key": "admin_restorative",
      "topic": "ai_assessment_integrity",
      "actor": "elise_admin",
      "side": "neutral",
      "content": "The first response to misuse should usually be restorative education, not automatic severe discipline."
    },
    {
      "key": "vendor_detection_warning",
      "topic": "ai_assessment_integrity",
      "actor": "samira_edtech",
      "side": "con",
      "content": "Schools should avoid relying on AI detectors as the main enforcement method because false positives can damage trust."
    },
    {
      "key": "privacy_no_training",
      "topic": "student_data_privacy",
      "actor": "noor_privacy",
      "side": "pro",
      "content": "The district should prohibit vendors from using student work, prompts, behavior, or metadata to train external models."
    },
    {
      "key": "student_data_visibility",
      "topic": "student_data_privacy",
      "actor": "lina",
      "side": "pro",
      "content": "Students should be able to see what data is collected and request correction or deletion when appropriate."
    },
    {
      "key": "parent_consent",
      "topic": "student_data_privacy",
      "actor": "fatima_parent",
      "side": "pro",
      "content": "Parents should receive plain-language consent notices before any tool collects identifiable student information."
    },
    {
      "key": "admin_vendor_contracts",
      "topic": "student_data_privacy",
      "actor": "elise_admin",
      "side": "pro",
      "content": "Procurement should require vendor security reviews, breach notification timelines, retention limits, and audit rights."
    },
    {
      "key": "edtech_minimal_data",
      "topic": "student_data_privacy",
      "actor": "samira_edtech",
      "side": "neutral",
      "content": "The best implementation is data minimization: the tool should work with the least student information possible."
    },
    {
      "key": "teacher_time",
      "topic": "teacher_workload_training",
      "actor": "marc_teacher",
      "side": "pro",
      "content": "Teachers need protected training time, not an extra unpaid expectation added on top of planning, grading, and classroom support."
    },
    {
      "key": "admin_templates",
      "topic": "teacher_workload_training",
      "actor": "elise_admin",
      "side": "pro",
      "content": "The district can reduce burden by providing model lesson plans, assessment templates, disclosure language, and parent communication drafts."
    },
    {
      "key": "student_consistency",
      "topic": "teacher_workload_training",
      "actor": "lina",
      "side": "pro",
      "content": "Students need consistent rules across classes because confusion grows when every teacher has a different AI policy."
    },
    {
      "key": "privacy_training",
      "topic": "teacher_workload_training",
      "actor": "noor_privacy",
      "side": "pro",
      "content": "Teacher training should include privacy basics, such as avoiding sensitive student data in prompts and understanding vendor terms."
    },
    {
      "key": "access_training",
      "topic": "teacher_workload_training",
      "actor": "diego_access",
      "side": "pro",
      "content": "Training should include accessibility use cases so AI is not treated only as a productivity tool for already-advantaged students."
    },
    {
      "key": "equity_device_access",
      "topic": "equity_access_funding",
      "actor": "diego_access",
      "side": "pro",
      "content": "No AI policy is equitable if students lack reliable devices, internet access, language support, or assistive technology."
    },
    {
      "key": "parent_cost",
      "topic": "equity_access_funding",
      "actor": "fatima_parent",
      "side": "pro",
      "content": "Families should not be asked to pay for approved tools. If a tool is required for learning, the school must provide it."
    },
    {
      "key": "student_support",
      "topic": "equity_access_funding",
      "actor": "lina",
      "side": "pro",
      "content": "Students who are learning the language of instruction or who have learning differences could benefit if the system is designed for them from the start."
    },
    {
      "key": "board_budget_tradeoff",
      "topic": "equity_access_funding",
      "actor": "julien_board",
      "side": "neutral",
      "content": "Equity funding is essential, but the board must decide what to pause or reduce if AI support becomes a funded priority."
    },
    {
      "key": "vendor_discount",
      "topic": "equity_access_funding",
      "actor": "samira_edtech",
      "side": "pro",
      "content": "Vendors should offer district-wide access pricing and accessibility features as core requirements, not premium add-ons."
    },
    {
      "key": "literacy_required",
      "topic": "ai_literacy_curriculum",
      "actor": "elise_admin",
      "side": "pro",
      "content": "AI literacy should become a required strand because students will encounter AI systems across school, work, media, and civic life."
    },
    {
      "key": "privacy_curriculum",
      "topic": "ai_literacy_curriculum",
      "actor": "noor_privacy",
      "side": "pro",
      "content": "Students should learn what not to share, how data trails work, and how automated systems can infer sensitive information."
    },
    {
      "key": "teacher_curriculum_load",
      "topic": "ai_literacy_curriculum",
      "actor": "marc_teacher",
      "side": "neutral",
      "content": "AI literacy is important, but it should be integrated into existing subjects rather than becoming another disconnected requirement."
    },
    {
      "key": "student_bias_check",
      "topic": "ai_literacy_curriculum",
      "actor": "lina",
      "side": "pro",
      "content": "Students should learn how to check AI answers, find sources, detect bias, and explain when a result should not be trusted."
    },
    {
      "key": "parent_home_support",
      "topic": "ai_literacy_curriculum",
      "actor": "fatima_parent",
      "side": "pro",
      "content": "Families need simple guidance too, because students will use these tools at home even when teachers are not present."
    }
  ],
