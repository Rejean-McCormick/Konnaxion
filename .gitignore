##############################################################################
# ROOT .gitignore (backend + frontend)
##############################################################################

# Backups / local junk
Backups/
*.bak
*.orig
*.tmp
*.swp

##############################################################################
# 0) OS / Editors
##############################################################################
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

.idea/
.vscode/
*.sublime-workspace
*.sublime-project

##############################################################################
# 1) Logs / Reports / Caches
##############################################################################
*.log
logs/
coverage/
htmlcov/
.cache/
.nyc_output/
playwright-report/
test-results/
routes-tests.json
use_client_report.csv
use_client_report.json

##############################################################################
# 2) Secrets / Environment
##############################################################################
.env
.env.*
.envs/
!.env.example
!env.example
!*.example

##############################################################################
# 3) Python
##############################################################################
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.so

venv/
.venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.tox/
.dmypy.json
.pyre/
.pyright/
.ruff_cache/

*.sqlite3
*.db

##############################################################################
# 4) Node / Frontend
##############################################################################
node_modules/
.pnpm/
.pnp/
.pnp.js
.pnpm-store/
.ignored_node_modules/

.next/
out/
dist/
build/

.eslintcache
.prettiercache
*.tsbuildinfo
.turbo/
.swc/
.parcel-cache/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tgz

##############################################################################
# 5) Django / generated assets
##############################################################################
staticfiles/
media/

##############################################################################
# 6) Docker / local data
##############################################################################
**/local_postgres_data/
**/local_postgres_data_backups/
**/local_pgdata/
**/local_pgadmin/
**/.docker/
docker-compose.override.yml
compose/**/traefik/acme.json
compose/**/nginx/certs/

##############################################################################
# 7) Keep important project files
##############################################################################
!**/.dockerignore
!**/Dockerfile
!**/docker-compose*.yml
!**/compose*.yml
!**/requirements/
!**/requirements/*.txt
!**/migrations/
!**/migrations/*.py
!**/package.json
!**/pnpm-lock.yaml
!**/next.config.*
!**/tsconfig.json
!*.md