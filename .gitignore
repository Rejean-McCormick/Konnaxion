##############################################################################
# ROOT .gitignore (common folder holding backend + frontend)
# Goal: avoid duplicates; keep repo-wide rules only
##############################################################################

# Backups / local junk
Backups/
*.bak
*.orig
*.tmp
*.swp

##############################################################################
# 0) OS / Editors
##############################################################################
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

.idea/
.vscode/
*.sublime-workspace
*.sublime-project

##############################################################################
# 1) Logs / Reports / Caches (generic)
##############################################################################
*.log
logs/
coverage/
htmlcov/
.cache/
.nyc_output/
reports/
artifacts/
playwright-report/
test-results/
routes-tests.json
use_client_report.csv
use_client_report.json

##############################################################################
# 2) Secrets / Environment
##############################################################################
.env
.env.*
.envs/
!.env.example

##############################################################################
# 3) Python (generic)
##############################################################################
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.so

# virtualenvs
venv/
.venv/
env/
ENV/

# tooling caches
.pytest_cache/
.mypy_cache/
.tox/
.dmypy.json
.pyre/
.pyright/
.ruff_cache/

# local dbs
*.sqlite3
*.db

##############################################################################
# 4) Node / Front tooling (generic)
##############################################################################
node_modules/
.pnpm/
.pnp/
.pnp.js
.pnpm-store/
.ignored_node_modules/

# builds
.next/
out/
dist/
build/

# caches
.eslintcache
.prettiercache
*.tsbuildinfo
.turbo/
.swc/
.parcel-cache/
.cache/

# package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tgz

##############################################################################
# 5) Django / Next generated assets (repo-wide safe defaults)
##############################################################################
staticfiles/
media/

##############################################################################
# 6) Docker / local data (common)
##############################################################################
**/local_postgres_data/
**/local_postgres_data_backups/
**/local_pgdata/
**/local_pgadmin/
**/.docker/
.dockerignore
docker-compose.override.yml
compose/**/traefik/acme.json
compose/**/nginx/certs/

##############################################################################
# 7) EXCEPTIONS (do not ignore these)
##############################################################################
!konnaxion/**/migrations/
!konnaxion/requirements/
!konnaxion/config/
!next-enterprise/package.json
!next-enterprise/tsconfig.json
!*.md
