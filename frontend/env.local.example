##############################################
# BACKEND API (local development)
##############################################
# Frontend talks to the local backend API.
NEXT_PUBLIC_API_BASE=http://localhost:8000/api

##############################################
# BUILD / ANALYZE
##############################################
ANALYZE=false

##############################################
# MAPBOX
##############################################
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.__your_mapbox_token__
MAPBOX_ACCESS_TOKEN=pk.__your_mapbox_token__

##############################################
# AUTH0 (local development)
##############################################
AUTH0_SECRET=replace_with_a_real_random_secret_locally
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH0_CLIENT_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
APP_BASE_URL=http://localhost:3000

##############################################
# DEVELOPMENT OPTIONS
##############################################
NODE_ENV=development
